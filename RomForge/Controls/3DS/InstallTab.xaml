<UserControl x:Class="RomForge.Controls._3DS.InstallTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Common.WPF.Converters;assembly=Common.WPF">

    <UserControl.Resources>
        <converters:RegionToImageConverter x:Key="RegionToFlagImageConverter"/>
    </UserControl.Resources>

    <Grid Background="#0F0F13">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="23*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 파일 리스트 -->
        <ListView x:Name="InstallListView"
                  Grid.Row="0" Grid.ColumnSpan="2"
                  SelectionMode="Extended"
                  AllowDrop="True"
                  Drop="InstallList_Drop"
                  DragOver="InstallList_DragOver"
                  KeyUp="InstallList_KeyUp"
                  HorizontalContentAlignment="Stretch"
                  IsEnabled="{Binding Install.IsNotInstalling}"
                  Visibility="{Binding Install.ListVisibility}">

            <ListView.Template>
                <ControlTemplate TargetType="ListView">
                    <Grid>
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                        <Border x:Name="DropHint" IsHitTestVisible="False"
                                Margin="15,45,15,15"
                                Visibility="{Binding Install.HintVisibility}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.85">
                                <Image Source="/Assets/Images/drag.png" Width="40" Height="40" Margin="0,0,0,8"/>
                                <TextBlock Text="3DS 파일(CIA, CCI, ZCCI) 또는 폴더를 드래그하세요"
                                           Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </ListView.Template>

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="타이틀" Width="280">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,5">
                                    <Border Width="36" Height="36" CornerRadius="6" Margin="0,0,12,0">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding Icon}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ShortDescription}" Foreground="#E8E8F0" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="260" ToolTip="{Binding FilePath}"/>
                                        <TextBlock Text="{Binding Publisher}" Foreground="#8888A8" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" MaxWidth="260"  ToolTip="{Binding FilePath}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="종류" Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding TypeBadgeColor}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Center" Margin="8,0">
                                    <TextBlock Text="{Binding TypeLabel}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="제품 코드" Width="140">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding ProductCode}" Foreground="#8888A8" FontSize="12" Margin="8,0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding TitleId}" Foreground="#555570" FontSize="10" Margin="8,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="지역" Width="60">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Width="24" Height="24" Margin="8,0" 
                                       Source="{Binding ProductCode, Converter={StaticResource RegionToFlagImageConverter}}" ToolTip="{Binding Region}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="암호화" Width="60">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding LockIcon}" FontSize="14" Margin="8,0" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="크기" Width="90">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SizeText}" Foreground="#8888A8" FontSize="12" Margin="8,0" HorizontalAlignment="Right"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="진행률" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="8,0">
                                    <ProgressBar Value="{Binding Progress}" Maximum="100"
                                                 Style="{StaticResource ProgressBarStyle}" Height="18"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ProgressText}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        <TextBlock Text="%" Foreground="White" FontSize="10" FontWeight="Bold" Margin="1,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 버튼 바 -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                Background="#252526" Padding="8,6"
                BorderBrush="#2A2A3A" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="InstallButton" Style="{StaticResource PrimaryButton}" Click="Install_Click" IsEnabled="{Binding CanInstall}" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/Images/Run.png" Width="24" Height="24" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="설치" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="InstallCancelButton" Style="{StaticResource SecondaryButton}" Click="InstallCancel_Click" IsEnabled="{Binding Install.IsInstalling}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/Images/Cancel.png" Width="24" Height="24" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="취소" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" IsEnabled="{Binding CanInstall}">
                    <Button Style="{StaticResource SecondaryButton}" Click="InstallAddFiles_Click" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/Images/AddFile.png" Width="24" Height="24" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="파일 추가" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Click="InstallAddFolder_Click" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/Images/AddFolder.png" Width="24" Height="24" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="폴더 추가" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Click="InstallRemove_Click" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/Images/Delete.png" Width="24" Height="24" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="선택 삭제" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Click="InstallClear_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/Images/Clear.png" Width="24" Height="24" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="전체 삭제" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>