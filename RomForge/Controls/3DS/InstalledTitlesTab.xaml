<UserControl x:Class="RomForge.Controls._3DS.InstalledTitlesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Common.WPF.Converters;assembly=Common.WPF">

    <UserControl.Resources>
        <converters:RegionToImageConverter x:Key="RegionToFlagImageConverter"/>
    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="17*"/>
            <ColumnDefinition Width="93*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 검색 + 필터 -->
        <Border Grid.Row="0" Padding="16,10" Grid.ColumnSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#1E1E1E"
                        BorderBrush="#2A2A3A"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Grid>
                        <TextBlock Text="🔍   게임 검색..." Foreground="#8888A8" FontSize="13" Margin="12,0,0,0"
                                   VerticalAlignment="Center" IsHitTestVisible="False"
                                   Visibility="{Binding InstalledTitles.SearchHintVisibility}"/>
                        <TextBox x:Name="SearchBox"
                                 Background="Transparent" Foreground="#E8E8F0"
                                 BorderThickness="0" Padding="12,8" FontSize="13"
                                 CaretBrush="#4F8EF7"
                                 TextChanged="Search_TextChanged"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ToggleButton x:Name="FilterAll"    Content="전체"    IsChecked="True" Tag="All"    Style="{StaticResource FilterToggle}" Click="Filter_Click" IsEnabled="{Binding IsUnlocked}"/>
                    <ToggleButton x:Name="FilterGame"   Content="본편"    Foreground="#4F8EF7" Tag="Game"   Style="{StaticResource FilterToggle}" Click="Filter_Click" IsEnabled="{Binding IsUnlocked}"/>
                    <ToggleButton x:Name="FilterUpdate" Content="업데이트" Foreground="#3DD68C" Tag="Update" Style="{StaticResource FilterToggle}" Click="Filter_Click" IsEnabled="{Binding IsUnlocked}"/>
                    <ToggleButton x:Name="FilterDlc"    Content="DLC"     Foreground="#C97BF7" Tag="Dlc"    Style="{StaticResource FilterToggle}" Click="Filter_Click" Margin="0" IsEnabled="{Binding IsUnlocked}"/>

                    <Button x:Name="LoadButton" Style="{StaticResource PrimaryButton}" Margin="20,0,0,0" IsEnabled="{Binding CanLoad}" Click="LoadTitles_Click">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Assets/Images/Loading.png" Width="24" Height="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="게임목록 불러오기" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 리스트 영역 -->
        <Grid Margin="12,55,12,12" Grid.ColumnSpan="2" Grid.RowSpan="2">

            <!-- 로딩 -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding InstalledTitles.LoadingVisibility}">
                <TextBlock Text="⏳" FontSize="36" HorizontalAlignment="Center"/>
                <TextBlock x:Name="LoadingText" Text="로딩 중..."
                           Foreground="#8888A8" FontSize="15" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <ProgressBar x:Name="LoadingProgress"
                             Width="240" Height="3" Margin="0,16,0,0"
                             Background="#2A2A3A" Foreground="#4F8EF7" BorderThickness="0"/>
            </StackPanel>

            <!-- 빈 상태 -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Opacity="0.85" BorderThickness="1" Margin="15,45,15,15" CornerRadius="6"
                    Visibility="{Binding InstalledTitles.EmptyVisibility}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.85">
                    <Image Source="/Assets/Images/SdCard.png" Width="48" Height="48" Margin="0,0,0,8"/>
                    <TextBlock Text="SD 카드를 선택하고 설치 목록을 불러오세요"
                               Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 타이틀 리스트 -->
            <ListView x:Name="TitleListView" SelectionMode="Extended" Visibility="{Binding InstalledTitles.ListVisibility}" ContextMenuOpening="ContextMenu_Opening" IsEnabled="{Binding IsUnlocked}">
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="MenuExtractCia" Header="CIA로 추출" Click="ExtractTitle_Click">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Images/DLC.png" Width="24" Height="24"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem x:Name="MenuExtractCci" Header="CCI로 추출" Click="ExtractTitle_Click">
                            <MenuItem.Icon>
                                <Image Source="/Assets/Images/Cartridge.png" Width="24" Height="24"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </ListView.ContextMenu>
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="타이틀" Width="300">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,5">
                                        <Border Width="36" Height="36" CornerRadius="6" Margin="0,0,12,0">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding Icon}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ShortDescription}" Foreground="#E8E8F0" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                                            <TextBlock Text="{Binding Publisher}" Foreground="#8888A8" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="종류" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding TypeBadgeColor}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Center" Margin="8,0">
                                        <TextBlock Text="{Binding TypeLabel}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="제품 코드" Width="140">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProductCode}" Foreground="#8888A8" FontSize="12" Margin="8,0" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding TitleId}" Foreground="#555570" FontSize="10" Margin="8,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="지역" Width="60">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Width="24" Height="24" Margin="8,0" 
                                       Source="{Binding ProductCode, Converter={StaticResource RegionToFlagImageConverter}}" ToolTip="{Binding Region}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="암호화" Width="60">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding LockIcon}" FontSize="14" Margin="8,0" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="크기" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SizeText}" Foreground="#8888A8" FontSize="12" Margin="8,0" HorizontalAlignment="Right"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</UserControl>