<UserControl x:Class="RomForge.Controls.Util.MainTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.expression/blend/2008" 
             xmlns:local="clr-namespace:RomForge.Controls.Util"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid>
        <TabControl SelectedIndex="{Binding SubTabIndex, Mode=TwoWay}"
                    Background="Transparent" 
                    BorderThickness="0">

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/SD.png" Width="20" Height="20" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="SD 굽기" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <TextBlock Text="관리자 권한이 필요합니다." Visibility="{Binding IsNotAdmin, Converter={StaticResource BooleanToVisibilityConverter}}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <local:ZipImageToolTab DataContext="{Binding ZipImageToolVM}" Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/CUE.png" Width="20" Height="20" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Cue 생성" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid>
                    <local:CueTab DataContext="{Binding CueVM}"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>