<UserControl x:Class="RomForge.Controls.Switch.RepackTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:core="clr-namespace:NSW.WPF.UI;assembly=NSW.WPF"   
             mc:Ignorable="d" 
             d:DesignHeight="580" d:DesignWidth="800">
    <Grid>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0" Margin="0,0,0,5" SelectedIndex="0">
                <TabItem IsEnabled="{Binding IsIdle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/Images/AddFile.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="파일" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <core:FileManagerControl x:Name="fileMgr" IsEnabled="{Binding IsIdle}"/>
                </TabItem>
                <TabItem IsEnabled="{Binding IsIdle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/Images/Settings.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="설정" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <core:LanguageTabControl x:Name="langTab" IsEnabled="{Binding IsIdle}"/>
                </TabItem>
            </TabControl>

            <Grid Grid.Row="1" Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="5,0,5,0">
                    <Grid Height="30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Margin="0,0,5,0" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="6" AllowDrop="True" PreviewDragEnter="TxtPatch_DragEnter" PreviewDragOver="TxtPatch_DragOver" PreviewDrop="TxtPatch_Drop">
                            <Grid>
                                <TextBox x:Name="txtPatch" Text="{Binding PatchPath, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsIdle}" Background="Transparent" BorderThickness="0" Foreground="#DCDCDC" FontSize="11" VerticalContentAlignment="Center" Padding="10,0"/>
                                <TextBlock Text="한글패치 / xdelta 폴더를 드래그&amp;드롭하세요" Visibility="{Binding PatchHintVisibility}" Foreground="#50FFFFFF" FontSize="11" VerticalAlignment="Center" Margin="5,0,0,0" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <Button Grid.Column="1" x:Name="btnOpenPatchFolder" Width="30" Height="30" Padding="0" BorderThickness="1" Style="{StaticResource GrayButton}" Command="{Binding BrowsePatchCommand}" IsEnabled="{Binding IsIdle}" Margin="5,0,0,0">
                            <Image Source="/Assets/Images/AddFolder.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality" />
                        </Button>
                    </Grid>

                    <Grid Height="30" Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Margin="0,0,5,0" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="6" AllowDrop="True" PreviewDragEnter="TxtDlc_DragEnter" PreviewDragOver="TxtDlc_DragOver" PreviewDrop="TxtDlc_Drop">
                            <Grid>
                                <TextBox x:Name="txtDlc" Text="{Binding DlcPath, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsIdle}" Background="Transparent" BorderThickness="0" Foreground="#DCDCDC" FontSize="11" VerticalContentAlignment="Center" Padding="10,0"/>
                                <TextBlock Text="한글패치 DLC 루트 폴더를 드래그&amp;드롭하세요" Visibility="{Binding DlcHintVisibility}" Foreground="#50FFFFFF" FontSize="11" VerticalAlignment="Center" Margin="5,0,0,0" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <Button Grid.Column="1" x:Name="btnOpenDlcFolder" Width="30" Height="30" Padding="0" BorderThickness="1" Style="{StaticResource GrayButton}" Command="{Binding BrowseDlcCommand}" IsEnabled="{Binding IsIdle}" Margin="5,0,0,0">
                            <Image Source="/Assets/Images/AddFolder.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="5,0,5,0" VerticalAlignment="Center">
                    <TextBlock Text="작업 폴더" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,5"/>
                    <Grid Height="30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Margin="0,0,5,0" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <TextBox x:Name="txtOutput" Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsIdle}" Background="Transparent" BorderThickness="0" Foreground="#DCDCDC" FontSize="11" VerticalContentAlignment="Center" Padding="10,0"/>
                                <TextBlock Text="작업 폴더를 선택하세요" Visibility="{Binding OutputHintVisibility}" Foreground="#50FFFFFF" FontSize="11" VerticalAlignment="Center" IsHitTestVisible="False" Margin="5,0,0,0"/>
                            </Grid>
                        </Border>
                        <Button Grid.Column="1" x:Name="btnOpenWorkSpaceFolder" Width="30" Height="30" Padding="0" BorderThickness="1" Style="{StaticResource GrayButton}" Command="{Binding BrowseOutputCommand}" IsEnabled="{Binding IsIdle}" Margin="5,0,0,0">
                            <Image Source="/Assets/Images/AddFolder.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2" Margin="5,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <core:IconButton Grid.Column="0"
                     DefaultText="언팩"
                     DefaultIcon="/Assets/Images/Unpack.png"
                     CancelText="취소"
                     CancelIcon="/Assets/Images/Cancel.png"
                     IsRunning="{Binding IsUnpackRunning}"
                     IsEnabled="{Binding UnpackEnabled}"
                     Click="BtnUnpack_Click"/>

                <core:IconButton Grid.Column="1"
                     Margin="5,0,0,0"
                     DefaultText="리팩"
                     DefaultIcon="/Assets/Images/Repack.png"
                     CancelText="취소"
                     CancelIcon="/Assets/Images/Cancel.png"
                     IsRunning="{Binding IsRebuildRunning}"
                     IsEnabled="{Binding RebuildEnabled}"
                     Click="BtnRebuild_Click"/>

                <core:IconButton Grid.Column="2"
                     Margin="5,0,5,0"
                     DefaultText="언팩 + 리팩 (Full)"
                     DefaultIcon="/Assets/Images/Run.png"
                     CancelText="취소"
                     CancelIcon="/Assets/Images/Cancel.png"
                     IsRunning="{Binding IsFullRunning}"
                     IsEnabled="{Binding StartEnabled}"
                     Click="BtnStart_Click"/>
            </Grid>
            <Grid Grid.Row="3" Margin="5,0,5,0" Visibility="{Binding IsLocked, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding ProgressLabel}" Foreground="#A0A0A0" FontSize="11"/>
                <ProgressBar Grid.Row="1" Value="{Binding ProgressPct}" Minimum="0" Maximum="100" Height="5" Margin="0,5,0,0">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Grid>
                                <Border Background="#25FFFFFF" CornerRadius="2"/>
                                <Border x:Name="PART_Track" CornerRadius="2"/>
                                <Border x:Name="PART_Indicator" Background="#4CAF50" CornerRadius="2" HorizontalAlignment="Left"/>
                            </Grid>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
            </Grid>
            
        </Grid>
    </Grid>
</UserControl>
