<UserControl x:Class="RomForge.Controls.Switch.ConvertSaturnTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:core="clr-namespace:NSW.WPF.UI;assembly=NSW.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="580" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="160"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="5,5,5,10">
            <TextBlock Text="CUE 파일 경로" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,5"/>
            <Grid Height="36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Margin="0,0,5,0" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="6" AllowDrop="True" PreviewDrop="Cue_Drop" PreviewDragOver="OnPreviewDragOver">
                    <Grid>
                        <TextBox Text="{Binding CuePath, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="#DCDCDC" FontSize="11" VerticalContentAlignment="Center" Padding="10,0" IsEnabled="{Binding IsIdle}"/>
                        <TextBlock Text="CUE 파일을 드래그&amp;드롭하세요" Visibility="{Binding CueHintVisibility}" Foreground="#50FFFFFF" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False"/>
                    </Grid>
                </Border>
                <Button Grid.Column="1" Width="30" Height="30" Padding="0" BorderThickness="1" Style="{StaticResource GrayButton}" Command="{Binding BrowseCueCommand}" IsEnabled="{Binding IsIdle}">
                    <Image Source="/Assets/Images/AddFile.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>
            </Grid>

            <TextBlock Text="원본 스위치 파일 경로" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,5,0,5"/>
            <Grid Height="36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Margin="0,0,5,0" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="6" AllowDrop="True" PreviewDrop="Nsp_Drop" PreviewDragOver="OnPreviewDragOver">
                    <Grid>
                        <TextBox Text="{Binding NspPath, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="#DCDCDC" FontSize="11" VerticalContentAlignment="Center" Padding="10,0" IsEnabled="{Binding IsIdle}" />
                        <TextBlock Text="원본 NSP/NSZ 파일을 드래그&amp;드롭하세요" Visibility="{Binding NspHintVisibility}" Foreground="#50FFFFFF" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False"/>
                    </Grid>
                </Border>
                <Button Grid.Column="1" Width="30" Height="30" Padding="0" BorderThickness="1" Style="{StaticResource GrayButton}" Command="{Binding BrowseNspCommand}" IsEnabled="{Binding IsIdle}">
                    <Image Source="/Assets/Images/AddFile.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="1" Margin="5,0,5,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="8" AllowDrop="True" PreviewDrop="Cover_Drop" PreviewDragOver="OnPreviewDragOver" IsEnabled="{Binding IsIdle}">
                <Grid>
                    <TextBlock Text="커버 이미지" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#50FFFFFF" FontSize="11" IsHitTestVisible="False" Visibility="{Binding CoverHintVisibility}"/>
                    <Image Source="{Binding CoverImagePath}" Stretch="Uniform" Margin="5"/>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="게임명" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,5"/>
                <Border Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="6" Height="36" Margin="0,0,0,15">
                    <TextBox Text="{Binding GameTitle, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="#DCDCDC" VerticalContentAlignment="Center" Padding="10,0" IsEnabled="{Binding IsIdle}"/>
                </Border>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="게임 ID" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding GameId}" IsReadOnly="True" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" Foreground="#DCDCDC" FontSize="11" Height="36" VerticalContentAlignment="Center" Padding="10,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="버전" FontSize="12" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding GameVersion}" IsReadOnly="True" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" Foreground="#DCDCDC" FontSize="11" Height="36" VerticalContentAlignment="Center" Padding="10,0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3" Margin="5,0,5,10">
            <core:IconButton DefaultText="작업 시작"
                             DefaultIcon="/Assets/Images/Run.png"
                             CancelText="취소"
                             CancelIcon="/Assets/Images/Cancel.png"
                             IsRunning="{Binding IsConverting}"
                             Click="BtnStart_Click"/>
        </Grid>

        <Border Grid.Row="4" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="0,1,0,0" CornerRadius="8" Margin="5,0,5,5" Padding="8,0">
            <Grid x:Name="progressArea" Height="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="progressLabel" Text="{Binding ProgressLabel}" Foreground="#A0A0A0" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" x:Name="progressPercent" Margin="0,0,10,0" Text="{Binding ProgressPercent}" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="progressSpeed" Margin="0,0,10,0" Text="{Binding ProgressSpeed}" Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" x:Name="progressTime" Margin="0,0,10,0" Text="{Binding ProgressTime}" Foreground="#4CAF50" FontSize="11" VerticalAlignment="Center"/>
                <Grid Grid.Column="4" Height="10" VerticalAlignment="Center">
                    <Border Background="#25FFFFFF" CornerRadius="5"/>
                    <Border x:Name="barTrack" CornerRadius="5" ClipToBounds="True">
                        <Border Background="#4CAF50" CornerRadius="5" HorizontalAlignment="Left">
                            <Border.Width>
                                <MultiBinding Converter="{StaticResource ProgressToWidthConverter}">
                                    <Binding Path="ActualWidth" ElementName="barTrack"/>
                                    <Binding Path="ProgressPct"/>
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>