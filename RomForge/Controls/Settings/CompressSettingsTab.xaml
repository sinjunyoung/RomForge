<UserControl x:Class="RomForge.Controls.Settings.CompressSettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:RomForge.Converters">
    <TabControl>

        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/Images/Mame.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Chdman(chd)" VerticalAlignment="Center"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Border Style="{StaticResource OptionBorder}" Height="Auto" Padding="12,6">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/Images/Neural.png" Width="20" Margin="0,0,8,0"/>
                            <TextBlock Text="압축 알고리즘 (ISO: PSP, PS2)" Foreground="#A0A0A0" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ComboBox Margin="0,6,0,0" VerticalAlignment="Center"
                          ItemsSource="{Binding ChdmanCompressionOptions}"
                          SelectedItem="{Binding ChdmanCompression}"
                          DisplayMemberPath="Display"/>
                    </StackPanel>
                </Border>
            </Grid>
        </TabItem>

        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/Images/Switch.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Switch(nsz,xcz)" VerticalAlignment="Center"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Style="{StaticResource OptionBorder}" Height="Auto" Padding="12,6">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="압축 레벨" Foreground="#A0A0A0" FontSize="11" Margin="0,0,20,0"/>
                            <TextBlock FontSize="11" Foreground="White">무압축(NSP)</TextBlock>
                            <TextBlock FontSize="11" Foreground="Gray" Margin="20,0,20,0">|</TextBlock>
                            <TextBlock FontSize="11" Foreground="#00FFFF">3: 최대 속도</TextBlock>
                            <TextBlock FontSize="11" Foreground="Gray" Margin="20,0,20,0">|</TextBlock>
                            <TextBlock FontSize="11" Foreground="#66FFAD">9: 균형</TextBlock>
                            <TextBlock FontSize="11" Foreground="Gray" Margin="20,0,20,0">|</TextBlock>
                            <TextBlock FontSize="11" Foreground="#FFFF33">18: 권장</TextBlock>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Source="/Assets/Images/Level.png" Width="24" Margin="0,0,5,0"/>
                            <Slider Grid.Column="1" x:Name="sliderSwitch" Style="{StaticResource SliderStyle}"
                                    Minimum="2" Maximum="18" Value="{Binding SwitchCompressLevel}"
                                    SmallChange="1" LargeChange="1" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding ElementName=sliderSwitch, Path=Value, Converter={StaticResource CompressLevelTextConverter}}"
                                       Foreground="{Binding ElementName=sliderSwitch, Path=Value, Converter={StaticResource LevelToColorConverter}}"
                                       FontWeight="Bold" VerticalAlignment="Center" Width="30" TextAlignment="Center" Margin="5,0,0,0" MinWidth="45"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Grid.Row="2" Style="{StaticResource OptionBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="/Assets/Images/BlockMode.png" Width="20" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="압축 모드" Foreground="#A0A0A0" FontSize="11" VerticalAlignment="Center"/>
                        <Border Grid.Column="2" Width="1" Background="#3F3F46" Margin="12,8"/>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                            <RadioButton Content="블록" GroupName="SwitchBlockMode" IsChecked="{Binding SwitchUseBlockMode}" Margin="0,0,16,0"/>
                            <RadioButton Content="블록리스" GroupName="SwitchBlockMode" IsChecked="{Binding SwitchUseBlocklessMode}"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <ToggleButton Grid.Row="4" Style="{StaticResource ToggleStyle}"
                              IsChecked="{Binding SwitchIsValidationEnabled}">
                    <StackPanel Orientation="Horizontal">
                        <Image Width="18" Margin="0,0,10,0" Source="{Binding SwitchIsValidationEnabled, Converter={StaticResource BoolToImageConverter}}"/>
                        <TextBlock Text="압축 무결성 검증 : 압축 후 원본과 해시 비교 검증" VerticalAlignment="Center" FontSize="12"/>
                    </StackPanel>
                </ToggleButton>
            </Grid>
        </TabItem>

        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/Images/Azahar.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Azahar(zcci)" VerticalAlignment="Center"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Border Style="{StaticResource OptionBorder}" Height="Auto" Padding="12,6">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="압축 레벨" Foreground="#A0A0A0" FontSize="11" Margin="0,0,20,0"/>
                            <TextBlock FontSize="11" Foreground="#00FFFF">3: 최대 속도</TextBlock>
                            <TextBlock FontSize="11" Foreground="Gray" Margin="20,0,20,0">|</TextBlock>
                            <TextBlock FontSize="11" Foreground="#66FFAD">9: 균형</TextBlock>
                            <TextBlock FontSize="11" Foreground="Gray" Margin="20,0,20,0">|</TextBlock>
                            <TextBlock FontSize="11" Foreground="#FFFF33">18: 권장</TextBlock>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Source="/Assets/Images/Level.png" Width="24" Margin="0,0,10,0"/>
                            <Slider Grid.Column="1" x:Name="sliderAzahar" Style="{StaticResource SliderStyle}"
                                    Minimum="3" Maximum="18" Value="{Binding AzaharCompressLevel}"
                                    SmallChange="1" LargeChange="1" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding ElementName=sliderAzahar, Path=Value}"
                                       Foreground="{Binding ElementName=sliderAzahar, Path=Value, Converter={StaticResource LevelToColorConverter}}"
                                       FontWeight="Bold" VerticalAlignment="Center" Width="30" TextAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </TabItem>

        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="/Assets/Images/Dolphin.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Dolphin(rvz)" VerticalAlignment="Center"/>
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Border Style="{StaticResource OptionBorder}" Height="Auto" Padding="12,6">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="압축 레벨" Foreground="#A0A0A0" FontSize="11" Margin="0,0,20,0"/>
                            <TextBlock FontSize="11" Foreground="#00FFFF">3: 최대 속도</TextBlock>
                            <TextBlock FontSize="11" Foreground="Gray" Margin="20,0,20,0">|</TextBlock>
                            <TextBlock FontSize="11" Foreground="#66FFAD">9: 균형</TextBlock>
                            <TextBlock FontSize="11" Foreground="Gray" Margin="20,0,20,0">|</TextBlock>
                            <TextBlock FontSize="11" Foreground="#FFFF33">18: 권장</TextBlock>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Source="/Assets/Images/Level.png" Width="24" Margin="0,0,10,0"/>
                            <Slider Grid.Column="1" x:Name="sliderDolphin" Style="{StaticResource SliderStyle}"
                                    Minimum="3" Maximum="18" Value="{Binding DolphinCompressLevel}"
                                    SmallChange="1" LargeChange="1" IsSnapToTickEnabled="True" TickFrequency="1" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding ElementName=sliderDolphin, Path=Value}"
                                       Foreground="{Binding ElementName=sliderDolphin, Path=Value, Converter={StaticResource LevelToColorConverter}}"
                                       FontWeight="Bold" VerticalAlignment="Center" Width="30" TextAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </TabItem>

    </TabControl>
</UserControl>