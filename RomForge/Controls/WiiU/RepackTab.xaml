<UserControl x:Class="RomForge.Controls.WiiU.RepackTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:RomForge.ViewModels.WiiU"
             xmlns:core="clr-namespace:NSW.WPF.UI;assembly=NSW.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="640" d:DesignWidth="800"
             AllowDrop="True" DragEnter="Root_DragEnter" DragOver="Root_DragEnter" Drop="Root_Drop">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 목록 -->
        <Border Grid.Row="0" Margin="5,0,5,10" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="8" IsEnabled="{Binding IsIdle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <ListView ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}" Background="Transparent" BorderThickness="0" Margin="5" KeyUp="LvFiles_KeyUp" ContextMenuOpening="LvFiles_ContextMenuOpening">
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="폴더 열기" Click="MenuItem_OpenFolder_Click">
                                    <MenuItem.Icon>
                                        <Image Source="/Assets/Images/AddFolder.png" Width="20" Height="20"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="선택 삭제" Click="BtnRemove_Click">
                                    <MenuItem.Icon>
                                        <Image Source="/Assets/Images/Delete.png" Width="20" Height="20"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="전체 삭제" Click="BtnClear_Click">
                                    <MenuItem.Icon>
                                        <Image Source="/Assets/Images/Clear.png" Width="20" Height="20"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="종류" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding KindBackground}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Kind}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="타이틀" Width="260">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,5">
                                                <Border Width="36" Height="36" CornerRadius="6" Margin="0,0,10,0" Background="#252526" ClipToBounds="True">
                                                    <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#E8E8F0" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="200" ToolTip="{Binding DisplayName}"/>
                                                    <TextBlock Text="{Binding TitleIdVersionDisplay}" Foreground="#8888A8" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="한글패치" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="32" Height="32" Padding="0" ToolTip="{Binding PatchDisplay}" Command="{Binding DataContext.SetPatchCommand, RelativeSource={RelativeSource AncestorType=ListView}}" CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource PatchButton}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PatchPath}" Value="{x:Null}">
                                                                <Setter Property="Background" Value="#3A3A40"/>
                                                                <Setter Property="BorderBrush" Value="#5A5A62"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Image Source="/Assets/Images/Patch.png" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Button>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="경로" Width="220" DisplayMemberBinding="{Binding FilePath}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Border IsHitTestVisible="False" Visibility="{Binding EntriesHintVisibility}" BorderBrush="#333337" BorderThickness="1" Margin="15,15,15,15" CornerRadius="6" IsEnabled="{Binding IsIdle}">
                        <Border.Background>
                            <SolidColorBrush Color="#181818" Opacity="0.95"/>
                        </Border.Background>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.85">
                            <Image Source="/Assets/Images/drag.png" Width="28" Height="28" Margin="0,0,0,8"/>
                            <TextBlock Text="게임 파일 / 폴더를 여기에 드래그&amp;드롭하세요" Foreground="LightGray" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="본편/업데이트/DLC는 title ID로 자동 분류됩니다" Foreground="#D4AF37" FontSize="12" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                            <ItemsControl HorizontalAlignment="Center" Margin="0,8,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.Items>
                                    <Border Background="#1A4D56B2" BorderBrush="#4D4D56B2" BorderThickness="1" CornerRadius="6" Padding="10,4" Margin="4,0">
                                        <TextBlock Text="WUD" Foreground="#8FA3FF" FontWeight="Bold" FontSize="11" VerticalAlignment="Center">
                                            <TextBlock.Effect>
                                                <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#8FA3FF" Opacity="0.4"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </Border>
                                    <Border Background="#1A9E5B24" BorderBrush="#559E5B24" BorderThickness="1" CornerRadius="6" Padding="10,4" Margin="4,0">
                                        <TextBlock Text="WUX" Foreground="#FFA254" FontWeight="Bold" FontSize="11" VerticalAlignment="Center">
                                            <TextBlock.Effect>
                                                <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#FFA254" Opacity="0.4"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </Border>
                                    <Border Background="#1A9E2469" BorderBrush="#559E2469" BorderThickness="1" CornerRadius="6" Padding="10,4" Margin="4,0">
                                        <TextBlock Text="WUA" Foreground="#FF73C9" FontWeight="Bold" FontSize="11" VerticalAlignment="Center">
                                            <TextBlock.Effect>
                                                <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#FF73C9" Opacity="0.4"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </Border>
                                    <Border Background="#1A1B8A5A" BorderBrush="#551B8A5A" BorderThickness="1" CornerRadius="6" Padding="10,4" Margin="4,0">
                                        <TextBlock Text="WUP" Foreground="#54FFB5" FontWeight="Bold" FontSize="11" VerticalAlignment="Center">
                                            <TextBlock.Effect>
                                                <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#54FFB5" Opacity="0.4"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </Border>
                                    <Border Background="#1A555555" BorderBrush="#4DFFFFFF" BorderThickness="1" CornerRadius="6" Padding="10,4" Margin="3,0">
                                        <TextBlock Text="Loadiine" Foreground="#CCCCCC" FontWeight="Bold" FontSize="10" VerticalAlignment="Center">
                                            <TextBlock.Effect>
                                                <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#FFFFFF" Opacity="0.2"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </Border>
                                </ItemsControl.Items>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Grid.Column="1" Margin="5" VerticalAlignment="Top">
                    <Button Width="30" Height="30" Margin="0,0,0,8" Padding="0" BorderThickness="1" Style="{StaticResource GrayButton}" Command="{Binding RemoveSelectedCommand}">
                        <Image Source="/Assets/Images/Delete.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality" ToolTip="선택 삭제"/>
                    </Button>
                    <Button Width="30" Height="30" Padding="0" BorderThickness="1" Style="{StaticResource GrayButton}" Command="{Binding RemoveAllCommand}">
                        <Image Source="/Assets/Images/Clear.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality" ToolTip="모두 삭제"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 출력 포맷 선택 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,0,0,10">
            <TextBlock Text="출력 포맷:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <RadioButton Content="WUA ( 에뮬레이터 )" GroupName="OutputFormat" IsChecked="{Binding IsWuaFormat}" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0" IsEnabled="{Binding IsIdle}"/>
            <RadioButton Content="WUP ( 실기 )" GroupName="OutputFormat" IsChecked="{Binding IsWupFormat}" Foreground="White" VerticalAlignment="Center" IsEnabled="{Binding IsIdle}"/>
        </StackPanel>

        <!-- 작업 폴더 -->
        <StackPanel Grid.Row="2" Margin="5,0,5,10">
            <Grid Height="36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Margin="0,0,5,0" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsIdle}" Background="Transparent" BorderThickness="0" Foreground="#DCDCDC" FontSize="11" VerticalContentAlignment="Center" Padding="10,0"/>
                        <TextBlock Text="작업 폴더를 선택하세요" Visibility="{Binding OutputHintVisibility}" Foreground="#50FFFFFF" FontSize="11" VerticalAlignment="Center" IsHitTestVisible="False" Margin="10,0,0,0"/>
                    </Grid>
                </Border>
                <Button Grid.Column="1" Width="30" Height="30" Padding="0" BorderThickness="1" Style="{StaticResource GrayButton}" Command="{Binding BrowseOutputCommand}" IsEnabled="{Binding IsIdle}" Margin="5,0,0,0">
                    <Image Source="/Assets/Images/AddFolder.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>
            </Grid>
        </StackPanel>

        <!-- 실행 버튼 -->
        <Grid Grid.Row="3" Margin="5,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <core:IconButton Grid.Column="0"
                             DefaultText="언팩"
                             DefaultIcon="/Assets/Images/Unpack.png"
                             CancelText="취소"
                             CancelIcon="/Assets/Images/Cancel.png"
                             IsRunning="{Binding IsUnpackRunning}"
                             IsEnabled="{Binding UnpackEnabled}"
                             Click="BtnUnpack_Click"/>

            <core:IconButton Grid.Column="1"
                             Margin="5,0,0,0"
                             DefaultText="리팩 (폴더 기반)"
                             DefaultIcon="/Assets/Images/Repack.png"
                             CancelText="취소"
                             CancelIcon="/Assets/Images/Cancel.png"
                             IsRunning="{Binding IsRebuildRunning}"
                             IsEnabled="{Binding RebuildEnabled}"
                             Click="BtnRebuild_Click"/>

            <core:IconButton Grid.Column="2"
                             Margin="5,0,5,0"
                             DefaultText="언팩 + 리팩 (Full)"
                             DefaultIcon="/Assets/Images/Run.png"
                             CancelText="취소"
                             CancelIcon="/Assets/Images/Cancel.png"
                             IsRunning="{Binding IsFullRunning}"
                             IsEnabled="{Binding StartEnabled}"
                             Click="BtnStart_Click"/>
        </Grid>

        <!-- 진행률 -->
        <Border Grid.Row="4" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="0,1,0,0" CornerRadius="8" Margin="5,0,5,5" Padding="8,0">
            <Grid Height="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding ProgressLabel}" Foreground="#A0A0A0" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Margin="0,0,10,0" Text="{Binding ProgressPercent}" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Margin="0,0,10,0" Text="{Binding ProgressSpeed}" Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Margin="0,0,10,0" Text="{Binding ProgressTime}" Foreground="#4CAF50" FontSize="11" VerticalAlignment="Center"/>
                <Grid Grid.Column="4" Height="10" VerticalAlignment="Center">
                    <Border Background="#25FFFFFF" CornerRadius="5"/>
                    <Border x:Name="barTrack" CornerRadius="5" ClipToBounds="True">
                        <Border Background="#4CAF50" CornerRadius="5" HorizontalAlignment="Left">
                            <Border.Width>
                                <MultiBinding Converter="{StaticResource ProgressToWidthConverter}">
                                    <Binding Path="ActualWidth" ElementName="barTrack"/>
                                    <Binding Path="ProgressPct"/>
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>