<UserControl x:Class="RomForge.Controls.WiiU.RepackTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:RomForge.ViewModels.WiiU"
             xmlns:core="clr-namespace:NSW.WPF.UI;assembly=NSW.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="640" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 추가 버튼 4개 -->
        <Grid Grid.Row="0" Margin="5,0,5,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Margin="0,0,4,0" Height="36" Style="{StaticResource GrayButton}" Command="{Binding BrowseBaseFileCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Assets/Images/AddFile.png" Width="20" Height="20" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="본편 파일 추가" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="1" Margin="4,0,4,0" Height="36" Style="{StaticResource GrayButton}" Command="{Binding BrowseBaseFolderCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Assets/Images/AddFolder.png" Width="20" Height="20" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="본편 폴더 추가" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2" Margin="4,0,4,0" Height="36" Style="{StaticResource GrayButton}" Command="{Binding BrowseUpdateCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Assets/Images/AddFolder.png" Width="20" Height="20" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="업데이트 추가" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="3" Margin="4,0,0,0" Height="36" Style="{StaticResource GrayButton}" Command="{Binding BrowseDlcCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="/Assets/Images/AddFolder.png" Width="20" Height="20" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="DLC 추가" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 목록 -->
        <Border Grid.Row="1" Margin="5,0,5,10" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <ListView ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}" Background="Transparent" BorderThickness="0" Margin="5" KeyUp="LvFiles_KeyUp">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="종류" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding KindBackground}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Kind}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="타이틀" Width="260">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,5">
                                                <Border Width="36" Height="36" CornerRadius="6" Margin="0,0,10,0" Background="#252526" ClipToBounds="True">
                                                    <Image Source="{Binding Icon}" Stretch="UniformToFill"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#E8E8F0" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="200" ToolTip="{Binding DisplayName}"/>
                                                    <TextBlock Text="{Binding TitleIdVersionDisplay}" Foreground="#8888A8" FontSize="11" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="한글패치" Width="150" DisplayMemberBinding="{Binding PatchDisplay}"/>
                                <GridViewColumn Header="경로" Width="220" DisplayMemberBinding="{Binding FilePath}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Border IsHitTestVisible="False" Visibility="{Binding EntriesHintVisibility}" BorderBrush="#333337" BorderThickness="1" Margin="15,15,15,15" CornerRadius="6">
                        <Border.Background>
                            <SolidColorBrush Color="#181818" Opacity="0.95"/>
                        </Border.Background>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.85">
                            <TextBlock Text="위 버튼으로 본편 / 업데이트 / DLC를 추가하세요" Foreground="LightGray" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Grid.Column="1" Margin="5" VerticalAlignment="Top">
                    <Button Width="30" Height="30" Margin="0,0,0,8" Padding="0" BorderThickness="1" Style="{StaticResource GrayButton}" Command="{Binding BrowsePatchForSelectedCommand}">
                        <Image Source="/Assets/Images/Patch.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality" ToolTip="한글패치 폴더"/>
                    </Button>
                    <Button Width="30" Height="30" Margin="0,0,0,8" Padding="0" BorderThickness="1" Style="{StaticResource GrayButton}" Command="{Binding RemoveSelectedCommand}">
                        <Image Source="/Assets/Images/Delete.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality" ToolTip="선택 삭제"/>
                    </Button>
                    <Button Width="30" Height="30" Padding="0" BorderThickness="1" Style="{StaticResource GrayButton}" Command="{Binding RemoveAllCommand}">
                        <Image Source="/Assets/Images/Clear.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality" ToolTip="모두 삭제"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 출력 포맷 선택 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5,0,0,10">
            <TextBlock Text="출력 포맷:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <RadioButton Content="WUA" GroupName="OutputFormat" IsChecked="{Binding IsWuaFormat}" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <RadioButton Content="WUP (실기 설치용)" GroupName="OutputFormat" IsChecked="{Binding IsWupFormat}" Foreground="White" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 작업 폴더 -->
        <StackPanel Grid.Row="3" Margin="5,0,5,10">
            <Grid Height="36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Margin="0,0,5,0" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsIdle}" Background="Transparent" BorderThickness="0" Foreground="#DCDCDC" FontSize="11" VerticalContentAlignment="Center" Padding="10,0"/>
                        <TextBlock Text="작업 폴더를 선택하세요" Visibility="{Binding OutputHintVisibility}" Foreground="#50FFFFFF" FontSize="11" VerticalAlignment="Center" IsHitTestVisible="False" Margin="10,0,0,0"/>
                    </Grid>
                </Border>
                <Button Grid.Column="1" Width="30" Height="30" Padding="0" BorderThickness="1" Style="{StaticResource GrayButton}" Command="{Binding BrowseOutputCommand}" IsEnabled="{Binding IsIdle}" Margin="5,0,0,0">
                    <Image Source="/Assets/Images/AddFolder.png" Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>
            </Grid>
        </StackPanel>

        <!-- 실행 버튼 -->
        <Grid Grid.Row="4" Margin="5,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <core:IconButton Grid.Column="0"
                             DefaultText="언팩"
                             DefaultIcon="/Assets/Images/Unpack.png"
                             CancelText="취소"
                             CancelIcon="/Assets/Images/Cancel.png"
                             IsRunning="{Binding IsUnpackRunning}"
                             IsEnabled="{Binding UnpackEnabled}"
                             Click="BtnUnpack_Click"/>

            <core:IconButton Grid.Column="1"
                             Margin="5,0,0,0"
                             DefaultText="리팩 (폴더 기반)"
                             DefaultIcon="/Assets/Images/Repack.png"
                             CancelText="취소"
                             CancelIcon="/Assets/Images/Cancel.png"
                             IsRunning="{Binding IsRebuildRunning}"
                             IsEnabled="{Binding RebuildEnabled}"
                             Click="BtnRebuild_Click"/>

            <core:IconButton Grid.Column="2"
                             Margin="5,0,5,0"
                             DefaultText="언팩 + 리팩 (다이렉트)"
                             DefaultIcon="/Assets/Images/Run.png"
                             CancelText="취소"
                             CancelIcon="/Assets/Images/Cancel.png"
                             IsRunning="{Binding IsFullRunning}"
                             IsEnabled="{Binding StartEnabled}"
                             Click="BtnStart_Click"/>
        </Grid>

        <!-- 진행률 -->
        <Border Grid.Row="5" Background="#12FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="0,1,0,0" CornerRadius="8" Margin="5,0,5,5" Padding="8,0">
            <Grid Height="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding ProgressLabel}" Foreground="#A0A0A0" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1" Margin="0,0,10,0" Text="{Binding ProgressPercent}" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Margin="0,0,10,0" Text="{Binding ProgressSpeed}" Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Margin="0,0,10,0" Text="{Binding ProgressTime}" Foreground="#4CAF50" FontSize="11" VerticalAlignment="Center"/>
                <Grid Grid.Column="4" Height="10" VerticalAlignment="Center">
                    <Border Background="#25FFFFFF" CornerRadius="5"/>
                    <Border x:Name="barTrack" CornerRadius="5" ClipToBounds="True">
                        <Border Background="#4CAF50" CornerRadius="5" HorizontalAlignment="Left">
                            <Border.Width>
                                <MultiBinding Converter="{StaticResource ProgressToWidthConverter}">
                                    <Binding Path="ActualWidth" ElementName="barTrack"/>
                                    <Binding Path="ProgressPct"/>
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
