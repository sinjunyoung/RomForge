<UserControl x:Class="RomForge.Controls.PatchTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RomForge.Controls">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" SelectedIndex="{Binding PatchVM.SelectedTabIndex}">

            <TabItem IsEnabled="{Binding IsIdle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/Patch.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="일반" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="2,0,2,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource DropZone}" AllowDrop="True" Drop="NormalSourceDrop_Drop" MouseLeftButtonDown="NormalSourceDrop_Click">
                            <Grid Margin="14,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Source="/Assets/Images/AddFile.png" Width="28" Height="28" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PatchVM.NormalVM.SourceLabel}" Foreground="#888888" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,8,0,0"/>
                                </StackPanel>
                                <TextBlock Text="원본" Foreground="#888" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource DropZone}" AllowDrop="True" Drop="NormalPatchDrop_Drop" MouseLeftButtonDown="NormalPatchDrop_Click">
                            <Grid Margin="14,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Source="/Assets/Images/Patch.png" Width="28" Height="28" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PatchVM.NormalVM.PatchLabel}" Foreground="#888888" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,8,0,0"/>
                                </StackPanel>
                                <TextBlock Text="패치" Foreground="#888" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2"> 
                        <ProgressBar Value="{Binding PatchVM.NormalVM.Progress}" Maximum="100" Style="{StaticResource ProgressBarStyle}" Height="24"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PatchVM.NormalVM.Progress}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="%" Foreground="White" FontSize="10" FontWeight="Bold" Margin="1,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding PatchVM.NormalVM.StatusText}" Foreground="{Binding PatchVM.NormalVM.StatusColor}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,0"/>
                    </Grid>
                    <Border Grid.Row="4" BorderBrush="#333337" BorderThickness="1" CornerRadius="5" Padding="10,8" Margin="0,0,0,2">   
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image Source="/Assets/Images/Patch.png" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" FontSize="14" Foreground="#909090">
                                <Run Text="지원 패치 형식:" Foreground="#888888" FontWeight="Bold"/>
                                <Run Text=" IPS, BPS, UPS, PPF, APS, Xdelta" Foreground="#CCCCCC"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem IsEnabled="{Binding IsIdle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/FBNeo.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="아케이드" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="2,0,2,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource DropZone}" AllowDrop="True" Drop="ArcadeSourceDrop_Drop" MouseLeftButtonDown="ArcadeSourceDrop_Click">
                            <Grid Margin="14,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Source="/Assets/Images/ZipFile.png" Width="28" Height="28" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PatchVM.ArcadeVM.SourceLabel}" Foreground="#888888" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,8,0,0"/>
                                </StackPanel>
                                <TextBlock Text="원본 ZIP" Foreground="#888" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource DropZone}" AllowDrop="True" Drop="ArcadePatchDrop_Drop" MouseLeftButtonDown="ArcadePatchDrop_Click">
                            <Grid Margin="14,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Source="/Assets/Images/ZipFolder.png" Width="28" Height="28" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PatchVM.ArcadeVM.PatchLabel}" Foreground="#888888" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,8,0,0"/>
                                </StackPanel>
                                <TextBlock Text="패치(IPS/폴더/ZIP)" Foreground="#888" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PatchVM.ArcadeVM.MatchItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="12,3" Padding="10,6" CornerRadius="4" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="32"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SourceFileName}" Foreground="#DCDCDC" FontSize="12" TextTrimming="CharacterEllipsis" ToolTip="{Binding SourceFileName}"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1" Text="→" Foreground="#555555" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                            <Border Grid.Column="2" AllowDrop="True" Drop="MatchCard_PatchDrop" DragOver="MatchCard_DragOver" Tag="{Binding}" CornerRadius="3" Padding="8,4" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1E1E1E"/>
                                                        <Setter Property="BorderBrush" Value="#3F3F46"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PatchFileName}" Value="{x:Null}">
                                                                <Setter Property="BorderBrush" Value="#FF6B6B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis" ToolTip="{Binding PatchFileName}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding PatchFileName}"/>
                                                            <Setter Property="Foreground" Value="#DCDCDC"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PatchFileName}" Value="{x:Null}">
                                                                    <Setter Property="Text" Value="패치 파일을 드래그하세요"/>
                                                                    <Setter Property="Foreground" Value="#555555"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <Border Grid.Column="3" CornerRadius="4" Padding="8,3" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#2D7D46"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMatched}" Value="False">
                                                                <Setter Property="Background" Value="#7D2D2D"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontWeight="Bold" FontSize="11">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="매칭"/>
                                                            <Setter Property="Foreground" Value="#AAFFAA"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMatched}" Value="False">
                                                                    <Setter Property="Text" Value="미매칭"/>
                                                                    <Setter Property="Foreground" Value="#FFAAAA"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <Grid Grid.Column="4" Margin="6,0,0,0">
                                                <ProgressBar Value="{Binding Progress}" Maximum="100" Style="{StaticResource ProgressBarStyle}" Height="20"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Progress}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                    <TextBlock Text="%" Foreground="White" FontSize="10" FontWeight="Bold" Margin="1,0,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Grid.Row="1" IsHitTestVisible="False" Visibility="{Binding PatchVM.ArcadeVM.HintVisibility}" BorderBrush="#333337" BorderThickness="1" CornerRadius="6" Margin="0,4,0,2">
                        <Border.Background>
                            <SolidColorBrush Color="#181818" Opacity="0.95"/>
                        </Border.Background>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.90">
                            <Image Source="/Assets/Images/Info.png" Width="28" Height="28" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="원본 ZIP, 패치(IPS, 폴더, ZIP)를 위에 드래그하세요" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="확장자 기준으로 자동 매칭됩니다" Foreground="#888" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,2,0,4">
                        <ProgressBar Value="{Binding PatchVM.ArcadeVM.TotalProgress}" Maximum="100" Style="{StaticResource ProgressBarStyle}" Height="24"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PatchVM.ArcadeVM.TotalProgress}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="%" Foreground="White" FontSize="10" FontWeight="Bold" Margin="1,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding PatchVM.ArcadeVM.ProgressSummary}" Foreground="#DDDDDD" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem IsEnabled="{Binding IsIdle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/Switch.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Switch" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <controls:SwitchPatchTab/>
            </TabItem>

        </TabControl>

        <Border Grid.Row="1" Background="#252526" Padding="8,6" BorderBrush="#2D2D30" BorderThickness="0,1,0,0" CornerRadius="5">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource RunButton}" IsEnabled="{Binding PatchVM.IsLocked, Converter={StaticResource InverseBool}}" Command="{Binding PatchVM.RunCommand}" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Assets/Images/Run.png" Width="24" Height="24" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="패치 시작" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource GrayButton}" IsEnabled="{Binding PatchVM.IsLocked}" Command="{Binding PatchVM.CancelCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Assets/Images/Cancel.png" Width="24" Height="24" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="취소" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource GrayButton}" IsEnabled="{Binding PatchVM.IsLocked, Converter={StaticResource InverseBool}}" Command="{Binding PatchVM.ClearCommand}" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Assets/Images/Clear.png" Width="24" Height="24" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="초기화" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>