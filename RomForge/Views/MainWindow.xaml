<Window x:Class="RomForge.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:RomForge.Views"
        xmlns:controls="clr-namespace:RomForge.Controls"        
        xmlns:switch="clr-namespace:RomForge.Controls.Switch"
        xmlns:_3ds="clr-namespace:RomForge.Controls._3DS"
        xmlns:ps1="clr-namespace:RomForge.Controls.PS1"
        xmlns:util="clr-namespace:RomForge.Controls.Util"
        xmlns:settings="clr-namespace:RomForge.Controls.Settings"
        xmlns:vm="clr-namespace:RomForge.ViewModels"
        xmlns:helpers="clr-namespace:RomForge.Helpers"
        Title="{Binding AppVersion}"
        Height="720" Width="900"
        MinHeight="480" MinWidth="900"
        Background="#1E1E1E"
        AllowDrop="True"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="340"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="130" MinHeight="60"/>
        </Grid.RowDefinitions>

        <TabControl SelectedIndex="{Binding SelectedTabIndex}">

            <TabItem IsEnabled="{Binding IsIdle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/Patch.png" Width="16" Height="16" Margin="0,0,10,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="패치" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <controls:PatchTab/>
            </TabItem>

            <TabItem IsEnabled="{Binding IsIdle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/Compress.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="압축" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <controls:CompressTab/>
            </TabItem>

            <TabItem IsEnabled="{Binding IsIdle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/Switch.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Switch" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <switch:MainTab DataContext="{Binding SwitchMainVM}"/>
            </TabItem>

            <TabItem IsEnabled="{Binding IsIdle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/3DS.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="3DS" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <_3ds:MainTab DataContext="{Binding Main3DsVM}"/>
            </TabItem>

            <TabItem IsEnabled="{Binding IsIdle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/PS1.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="PSX" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <ps1:MainTab DataContext="{Binding PS1MainVM}"/>
            </TabItem>

            <TabItem IsEnabled="{Binding IsIdle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/Utility.png" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="유틸" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <util:MainTab DataContext="{Binding UtilMainVM}"/>
            </TabItem>

            <TabItem IsEnabled="{Binding IsIdle}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/Settings.png" Width="16" Height="16" Margin="0,0,10,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock Text="설정" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <settings:MainTab DataContext="{Binding Settings}"/>
            </TabItem>

        </TabControl>

        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#1E1E1E" Cursor="SizeNS"/>

        <Border BorderBrush="#444444" BorderThickness="1" CornerRadius="10" Background="Transparent" Grid.Row="2" Visibility="Hidden">
            <RichTextBox x:Name="logBox" Style="{StaticResource LogBox}" helpers:RichTextBoxLogger.LogEntries="{Binding ActiveLogEntries}" BorderThickness="0" Background="Transparent" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"/>
        </Border>
    </Grid>
</Window>